<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — PassGen</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500&family=Syne:wght@400;500;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

<nav class="navbar">
    <a class="navbar-brand" asp-controller="Home" asp-action="Index">
        <span class="brand-icon">⬡</span> PassGen
    </a>
    <div class="navbar-links">
        <a asp-controller="Home" asp-action="Index" class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")">Генератор</a>
        <a asp-controller="History" asp-action="Index" class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "History" ? "active" : "")">История</a>
    </div>
</nav>

<main class="main-content">
    @RenderBody()
</main>

<footer class="footer">
    <span>PassGen · ASP.NET Core MVC · CSPRNG · SQLite</span>
</footer>

<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
